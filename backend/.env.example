# Tavus CVI
TAVUS_API_KEY=tvs_xxx
TAVUS_PERSONA_ID=p_xxx
TAVUS_REPLICA_ID=r_xxx

# Open Dental MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=opendental

# Backend public URL (for Tavus webhook callbacks — use ngrok for local dev)
BACKEND_URL=https://your-backend.ngrok.io

# Twilio (optional, for SMS reminders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# CORS
FRONTEND_URL=http://localhost:5173

# Session limits
MAX_CALL_DURATION=300
PARTICIPANT_LEFT_TIMEOUT=30
